# OralGuard Deployment Configuration Template

# API & Reasoning Core
PROJECT_NAME=OralGuard
STORAGE_DIR=.oral_data
LAPLACIAN_THRESHOLD=50.0

# Pathologist Assistant (Gemini 3)
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=YOUR_GOOGLE_AI_STUDIO_KEY
AI_MODEL_NAME=gemini-3-flash-preview

# Inference & Diagnosis
MODEL_VERSION=v2.0.0-efficientnet-b4-kaggle
MODEL_PATH=models/oralguard_efficientnet_b4.pth
REFERRAL_THRESHOLD=0.60
UNCERTAINTY_THRESHOLD=0.45
FEATURE_EXTRACTION_ENABLED=True

# Cloud Config
# Replace with real endpoint for deployment
CLOUD_API_URL=http://localhost:8000/api/v1/mock-cloud/cases

# DB (SQLite for v1)
# SQLALCHEMY_DATABASE_URL=sqlite:///./.oral_data/oralguard.db
